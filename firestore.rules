rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────────────────────
    // Helpers
    // ──────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // Super admin: dueño del producto. Ve y edita todo.
    // Agrega aquí los UIDs que deben tener acceso global.
    function isSuperAdmin() {
      return isSignedIn() && request.auth.uid in [
        'w6uc7cHowgM4Pmsya4bUHt1G3Pu2'  // César
        // 'UID_DEL_PRIMO_AQUI'         // Agregar cuando se cree su cuenta — si quieres que sea super admin también
      ];
    }

    // Dueño de una quiniela: solo ve/edita las suyas.
    function esDuenoDeQuiniela(quinielaId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/quinielas/$(quinielaId)) &&
        get(/databases/$(database)/documents/quinielas/$(quinielaId)).data.ownerUid == request.auth.uid;
    }

    // Admin cliente "activo": tiene su doc en admins/ y el super admin lo habilitó.
    // GATE DURO: sin esto, un cliente no puede crear quinielas (ni aunque manipule
    // el cliente JS). El super admin controla el switch `activo` del lado servidor.
    function adminActivo() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.activo == true;
    }

    // ──────────────────────────────────────────────────────────────
    // admins/  (perfil + derechos de cada cuenta de cliente)
    // ──────────────────────────────────────────────────────────────
    match /admins/{uid} {

      // Cada cliente lee solo su propio doc; el super admin los lee todos.
      allow read: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());

      // Crear y borrar cuentas de cliente: solo super admin.
      allow create, delete: if isSuperAdmin();

      // Actualizar: el super admin puede todo. El dueño puede tocar SOLO campos
      // operativos (debeCambiarPassword, quinielasCreadas, nombre, empresa, telefono);
      // los campos de dinero/derechos quedan congelados a su valor actual para que
      // nadie se auto-otorgue acceso.
      allow update: if isSuperAdmin() || (
        isSignedIn() && request.auth.uid == uid &&
        request.resource.data.plan                == resource.data.plan &&
        request.resource.data.quinielasPermitidas == resource.data.quinielasPermitidas &&
        request.resource.data.activo              == resource.data.activo &&
        request.resource.data.temporadaHasta      == resource.data.temporadaHasta &&
        request.resource.data.email               == resource.data.email
      );
    }

    // ──────────────────────────────────────────────────────────────
    // quinielas/
    // ──────────────────────────────────────────────────────────────
    match /quinielas/{quinielaId} {

      // Lectura pública — necesaria para que el home, predicciones y ranking
      // funcionen sin login para participantes.
      allow read: if true;

      // Crear: el super admin siempre puede. Un admin cliente puede crear solo si
      // está ACTIVO (gate duro) y la quiniela queda a su nombre (ownerUid propio).
      allow create: if isSignedIn() &&
        (
          isSuperAdmin() ||
          (request.resource.data.ownerUid == request.auth.uid && adminActivo())
        );

      // Editar/borrar: super admin o el dueño.
      allow update, delete: if isSuperAdmin() ||
        (isSignedIn() && resource.data.ownerUid == request.auth.uid);
    }

    // ──────────────────────────────────────────────────────────────
    // predicciones/
    // ──────────────────────────────────────────────────────────────
    match /predicciones/{prediccionId} {

      // Lectura pública — el ranking las muestra a todos.
      allow read: if true;

      // Crear: validaciones estrictas + quiniela existe + dentro del plazo.
      // (El código de acceso se valida client-side. Las rules no lo enforce porque
      // codigoAcceso vive en el doc público de la quiniela; el código es protección
      // cosmética contra accesos casuales, no contra atacantes.)
      allow create: if
        // Estructura del doc: solo estas keys, ninguna extra
        request.resource.data.keys().hasOnly(
          ['quinielaId', 'nombre', 'picks', 'fecha', 'codigoAcceso']
        ) &&
        // Tipos básicos
        request.resource.data.quinielaId is string &&
        request.resource.data.nombre is string &&
        request.resource.data.picks is map &&
        request.resource.data.fecha is string &&
        // Tamaños razonables
        request.resource.data.nombre.size() >= 2 &&
        request.resource.data.nombre.size() <= 60 &&
        request.resource.data.nombre.trim() == request.resource.data.nombre &&
        request.resource.data.picks.size() <= 30 &&
        // La quiniela debe existir
        exists(/databases/$(database)/documents/quinielas/$(request.resource.data.quinielaId)) &&
        // Dentro del plazo de cierre (si la quiniela define `cierre`)
        (
          !('cierre' in get(/databases/$(database)/documents/quinielas/$(request.resource.data.quinielaId)).data) ||
          get(/databases/$(database)/documents/quinielas/$(request.resource.data.quinielaId)).data.cierre == null ||
          request.time < get(/databases/$(database)/documents/quinielas/$(request.resource.data.quinielaId)).data.cierre
        );

      // Las predicciones no se editan una vez enviadas.
      allow update: if false;

      // Borrar: super admin o dueño de la quiniela.
      allow delete: if isSuperAdmin() ||
        esDuenoDeQuiniela(resource.data.quinielaId);
    }

    // ──────────────────────────────────────────────────────────────
    // movimientos/  (caja interna del admin)
    // ──────────────────────────────────────────────────────────────
    // Solo super admin. Esta colección es contabilidad interna del producto
    // global — no escala por owner por ahora.
    match /movimientos/{movimientoId} {
      allow read, write: if isSuperAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // config/  (configuración global del producto)
    // ──────────────────────────────────────────────────────────────
    // config/home guarda qué secciones del inicio se muestran. Lectura
    // pública (el home la lee sin sesión); solo el super admin la edita.
    match /config/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
  }
}
