rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────────────────────
    // Helpers
    // ──────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // Super admin: dueño del producto. Ve y edita todo.
    // Agrega aquí los UIDs que deben tener acceso global.
    function isSuperAdmin() {
      return isSignedIn() && request.auth.uid in [
        'w6uc7cHowgM4Pmsya4bUHt1G3Pu2'  // César
        // 'UID_DEL_PRIMO_AQUI'         // Agregar cuando se cree su cuenta — si quieres que sea super admin también
      ];
    }

    // Dueño de una quiniela: solo ve/edita las suyas.
    function esDuenoDeQuiniela(quinielaId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/quinielas/$(quinielaId)) &&
        get(/databases/$(database)/documents/quinielas/$(quinielaId)).data.ownerUid == request.auth.uid;
    }

    // Admin cliente "activo": tiene su doc en admins/ y el super admin lo habilitó.
    // GATE DURO: sin esto, un cliente no puede crear quinielas (ni aunque manipule
    // el cliente JS). El super admin controla el switch `activo` del lado servidor.
    function adminActivo() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.activo == true;
    }

    // Cuota dura de quinielas por organizador (de por vida; solo el super admin
    // puede resetear el contador). Mantener en sync con MAX_QUINIELAS en admin.jsx.
    function maxQuinielas() {
      return 50;
    }

    // Cuenta vetada por el super admin: impide re-crear admins/{uid} tras un
    // "Eliminar cliente" (sin esto, un eliminado con correo verificado podría
    // auto-registrarse de nuevo con el mismo uid).
    function estaBloqueado() {
      return exists(/databases/$(database)/documents/bloqueados/$(request.auth.uid));
    }

    // ──────────────────────────────────────────────────────────────
    // admins/  (perfil + derechos de cada cuenta de cliente)
    // ──────────────────────────────────────────────────────────────
    match /admins/{uid} {

      // Cada cliente lee solo su propio doc; el super admin los lee todos.
      allow read: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());

      // Crear: el super admin (alta manual, sin restricciones) O auto-registro.
      // Auto-registro: el propio usuario, con correo VERIFICADO, no vetado, y un
      // doc con exactamente estos campos y valores seguros. `activo: true` es
      // deliberado: el registro es autoservicio; el abuso queda acotado por la
      // verificación de correo, la cuota de quinielas y App Check.
      allow create: if isSuperAdmin() || (
        isSignedIn() &&
        request.auth.uid == uid &&
        request.auth.token.email_verified == true &&
        !estaBloqueado() &&
        request.resource.data.keys().hasOnly(
          ['email', 'nombre', 'telefono', 'activo', 'creado', 'quinielasCreadas', 'origen']
        ) &&
        request.resource.data.email == request.auth.token.email &&
        request.resource.data.nombre is string &&
        request.resource.data.nombre.trim() == request.resource.data.nombre &&
        request.resource.data.nombre.size() >= 2 &&
        request.resource.data.nombre.size() <= 60 &&
        (
          request.resource.data.telefono == null ||
          (request.resource.data.telefono is string && request.resource.data.telefono.size() <= 20)
        ) &&
        request.resource.data.activo == true &&
        request.resource.data.creado == request.time &&
        request.resource.data.quinielasCreadas == 0 &&
        request.resource.data.origen == 'auto'
      );

      // Borrar cuentas de cliente: solo super admin.
      allow delete: if isSuperAdmin();

      // Actualizar: el super admin puede todo (incluye resetear el contador).
      // El dueño solo toca campos operativos (allowlist por diff) — `activo`,
      // `email` y `origen` quedan intocables para que nadie se auto-otorgue
      // acceso. `eliminada` es el marcador que deja la auto-eliminación de
      // cuenta justo antes de borrar el usuario de Auth. El contador de cuota
      // solo puede quedarse igual o subir exactamente +1 (el decremento/reset
      // queda prohibido: la cuota es de por vida salvo que el super admin la
      // resetee).
      allow update: if isSuperAdmin() || (
        isSignedIn() && request.auth.uid == uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(
          ['nombre', 'telefono', 'debeCambiarPassword', 'quinielasCreadas', 'eliminada']
        ) &&
        request.resource.data.get('eliminada', false) is bool &&
        (
          request.resource.data.get('quinielasCreadas', 0) == resource.data.get('quinielasCreadas', 0) ||
          request.resource.data.get('quinielasCreadas', 0) == resource.data.get('quinielasCreadas', 0) + 1
        )
      );
    }

    // ──────────────────────────────────────────────────────────────
    // bloqueados/  (veto de cuentas: impide el re-registro del perfil)
    // ──────────────────────────────────────────────────────────────
    // Escrito por el super admin al eliminar un cliente. El create de
    // admins/{uid} lo consulta vía estaBloqueado().
    match /bloqueados/{uid} {
      allow read, write: if isSuperAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // quinielas/
    // ──────────────────────────────────────────────────────────────
    match /quinielas/{quinielaId} {

      // Lectura pública — necesaria para que el home, predicciones y ranking
      // funcionen sin login para participantes.
      allow read: if true;

      // Crear: el super admin siempre puede (ID automático, sin cuota).
      // Un admin cliente puede crear solo si está ACTIVO (gate duro), la
      // quiniela queda a su nombre (ownerUid propio) y respeta la CUOTA:
      // su quiniela N debe llamarse "{uid}-{N}" y venir en el MISMO batch que
      // el incremento +1 de su contador quinielasCreadas. Como dos docs no
      // pueden compartir ID, es imposible colar más de una quiniela por
      // incremento (ni con batches manipulados desde la consola).
      allow create: if isSignedIn() &&
        (
          isSuperAdmin() ||
          (
            request.resource.data.ownerUid == request.auth.uid &&
            adminActivo() &&
            get(/databases/$(database)/documents/admins/$(request.auth.uid))
              .data.get('quinielasCreadas', 0) < maxQuinielas() &&
            getAfter(/databases/$(database)/documents/admins/$(request.auth.uid))
              .data.get('quinielasCreadas', 0) ==
              get(/databases/$(database)/documents/admins/$(request.auth.uid))
                .data.get('quinielasCreadas', 0) + 1 &&
            quinielaId == request.auth.uid + '-' +
              string(getAfter(/databases/$(database)/documents/admins/$(request.auth.uid))
                .data.get('quinielasCreadas', 0))
          )
        );

      // Editar/borrar: super admin o el dueño.
      allow update, delete: if isSuperAdmin() ||
        (isSignedIn() && resource.data.ownerUid == request.auth.uid);
    }

    // ──────────────────────────────────────────────────────────────
    // predicciones/
    // ──────────────────────────────────────────────────────────────
    match /predicciones/{prediccionId} {

      // Lectura pública — el ranking las muestra a todos.
      allow read: if true;

      // Crear: validaciones estrictas + quiniela existe + dentro del plazo.
      // (El código de acceso se valida client-side. Las rules no lo enforce porque
      // codigoAcceso vive en el doc público de la quiniela; el código es protección
      // cosmética contra accesos casuales, no contra atacantes.)
      allow create: if
        // Estructura del doc: solo estas keys, ninguna extra
        request.resource.data.keys().hasOnly(
          ['quinielaId', 'nombre', 'picks', 'fecha', 'codigoAcceso']
        ) &&
        // Tipos básicos
        request.resource.data.quinielaId is string &&
        request.resource.data.nombre is string &&
        request.resource.data.picks is map &&
        request.resource.data.fecha is string &&
        // Tamaños razonables
        request.resource.data.nombre.size() >= 2 &&
        request.resource.data.nombre.size() <= 60 &&
        request.resource.data.nombre.trim() == request.resource.data.nombre &&
        request.resource.data.picks.size() <= 30 &&
        // La quiniela debe existir
        exists(/databases/$(database)/documents/quinielas/$(request.resource.data.quinielaId)) &&
        // Dentro del plazo de cierre (si la quiniela define `cierre`)
        (
          !('cierre' in get(/databases/$(database)/documents/quinielas/$(request.resource.data.quinielaId)).data) ||
          get(/databases/$(database)/documents/quinielas/$(request.resource.data.quinielaId)).data.cierre == null ||
          request.time < get(/databases/$(database)/documents/quinielas/$(request.resource.data.quinielaId)).data.cierre
        );

      // Las predicciones no se editan una vez enviadas.
      allow update: if false;

      // Borrar: super admin o dueño de la quiniela.
      allow delete: if isSuperAdmin() ||
        esDuenoDeQuiniela(resource.data.quinielaId);
    }

    // ──────────────────────────────────────────────────────────────
    // movimientos/  (caja interna del admin)
    // ──────────────────────────────────────────────────────────────
    // Solo super admin. Esta colección es contabilidad interna del producto
    // global — no escala por owner por ahora.
    match /movimientos/{movimientoId} {
      allow read, write: if isSuperAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // donativos/  (registro de donativos vía Stripe)
    // ──────────────────────────────────────────────────────────────
    // Solo el webhook de Stripe (Admin SDK, bypassa estas reglas) escribe aquí.
    // Ningún cliente puede crear/editar/borrar donativos.
    match /donativos/{donativoId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    // ──────────────────────────────────────────────────────────────
    // config/  (configuración global del producto)
    // ──────────────────────────────────────────────────────────────
    // config/home guarda qué secciones del inicio se muestran. Lectura
    // pública (el home la lee sin sesión); solo el super admin la edita.
    match /config/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // analytics/  (estadísticas propias — solo contadores agregados)
    // ──────────────────────────────────────────────────────────────
    // Lectura: SOLO super admin. Los números nunca se filtran a los visitantes.
    //
    // Escritura: pública pero ACOTADA. Las páginas públicas suman +1 a contadores.
    // Permitimos solo campos conocidos (hasOnly) y limitamos el tamaño de los
    // mapas, de modo que nadie pueda crear campos basura ni inflar el documento
    // para gastar cuota. App Check (cuando se active) bloquea además a los bots.
    // Nota: por diseño un visitante podría inflar el VALOR de un contador; es una
    // métrica de vanidad sin impacto en datos sensibles, y App Check lo cierra.
    match /analytics/{docId} {
      allow read: if isSuperAdmin();
      allow write: if
        request.resource.data.keys().hasOnly(
          ['visitas', 'movil', 'escritorio', 'ios', 'android', 'horas', 'envios', 'aperturas', 'enVivo', 'dispositivos', 'anchoMovil', 'anchoEscritorio']
        ) &&
        (!('horas'           in request.resource.data) || request.resource.data.horas.size()           <= 24)  &&
        (!('aperturas'       in request.resource.data) || request.resource.data.aperturas.size()       <= 500) &&
        (!('enVivo'          in request.resource.data) || request.resource.data.enVivo.size()          <= 200) &&
        (!('anchoMovil'      in request.resource.data) || request.resource.data.anchoMovil.size()      <= 200) &&
        (!('anchoEscritorio' in request.resource.data) || request.resource.data.anchoEscritorio.size() <= 10);
    }
  }
}
